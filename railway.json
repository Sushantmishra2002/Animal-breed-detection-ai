{
  "version": 2,
  "services": {
    "backend": {
      "path": "backend",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT",
      "variables": {
        "PYTHONUNBUFFERED": "1",
        "PORT": "8000"
      },
      "ports": [
        {
          "port": 8000
        }
      ]
    },
    "frontend": {
      "path": "frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm start",
      "variables": {
        "REACT_APP_API_URL": "$BACKEND_URL"
      }
    }
  },
  "volumes": {
    "model": {
      "path": "/app/model"
    }
  }
}
